{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/v2", "destination": "/index-v2" },
    { "source": "/v3", "destination": "/index-v3" },
    { "source": "/obg", "destination": "/index-obg" },
    { "source": "/obg-desqualificado", "destination": "/index-obgdesqualificado" },
    { "source": "/rd", "destination": "/api/rd" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(webp|svg|jpg|jpeg|png|gif|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(css|js|woff|woff2|ttf)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
